{
  "name": "@svelterm/vt100",
  "version": "0.1.0",
  "description": "VT100/xterm terminal emulator — ANSI parser and cell grid",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./svelte": {
      "types": "./src/TerminalView.svelte",
      "svelte": "./src/TerminalView.svelte",
      "default": "./src/TerminalView.svelte"
    },
    "./EmbeddedTerminalDom": {
      "types": "./src/EmbeddedTerminalDom.svelte",
      "svelte": "./src/EmbeddedTerminalDom.svelte",
      "default": "./src/EmbeddedTerminalDom.svelte"
    },
    "./EmbeddedTerminalRegion": {
      "types": "./src/EmbeddedTerminalRegion.svelte",
      "svelte": "./src/EmbeddedTerminalRegion.svelte",
      "default": "./src/EmbeddedTerminalRegion.svelte"
    }
  },
  "files": [
    "dist/src",
    "src/TerminalView.svelte",
    "src/EmbeddedTerminalDom.svelte",
    "src/EmbeddedTerminalRegion.svelte",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test dist/test/*.test.js",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/opentype.js": "^1.3.9",
    "opentype.js": "^1.3.4",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "terminal",
    "vt100",
    "xterm",
    "ansi",
    "emulator"
  ],
  "author": "Tom Yandell",
  "license": "MIT"
}
